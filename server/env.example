# Database Connection strings:
# Local MongoDB (default Docker local setup):
MONGODB_URI=mongodb://<username>:<password>@localhost:27017/quickblog

# MongoDB Atlas (SRV):
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/quickblog?retryWrites=true&w=majority

# Server Configuration
PORT=5001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloudinary_cloud_name>
CLOUDINARY_API_KEY=<cloudinary_api_key>
CLOUDINARY_API_SECRET=<cloudinary_api_secret>

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Google Gemini AI (for content generation)
GEMINI_API_KEY=your_gemini_api_key_here